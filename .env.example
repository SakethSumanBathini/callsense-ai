# =============================================================================
# CallSense AI - Environment Variables
# =============================================================================

# API Authentication Key (used by judges to call your endpoint)
API_SECRET_KEY=sk_track3_987654321

# Sarvam AI - Speech-to-Text (Primary ASR Engine)
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Gemini - Primary LLM for Analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Groq - Fallback LLM (Llama 3.3 70B) + Fallback ASR (Whisper)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter - Secondary Fallback LLM
OPENROUTER_API_KEY=your_openrouter_api_key_here

# NVIDIA NIMs - Tertiary Fallback LLM
NVIDIA_API_KEY=your_nvidia_api_key_here

# LLM Provider Selection (gemini | groq | openrouter | nvidia)
LLM_PROVIDER=gemini

# Server Configuration
HOST=0.0.0.0
PORT=8000
